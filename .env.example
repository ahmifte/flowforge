# Copy this file to .env.local and fill in real values. Never commit .env.local.
#
# flowforge uses a BRING-YOUR-OWN-KEY model: users paste their own OpenAI API key
# in the UI, and it is sent per-request and never stored on the server. The
# variable below is an OPTIONAL fallback for local development only.

# Optional server-side fallback key for local dev. Leave blank in production.
OPENAI_API_KEY=

# Default model used when a workflow does not specify one.
OPENAI_MODEL=gpt-4o-mini

# --- Service / sales page (optional, public) ---
# Where the "Book a call" buttons point (e.g. your Calendly link).
NEXT_PUBLIC_BOOKING_URL=
# Fallback contact email shown when no booking URL is set.
NEXT_PUBLIC_CONTACT_EMAIL=you@example.com
